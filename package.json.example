{
  "_comment": "Lista de referência das dependências usadas pelo frontend B2/B3. Não é um package.json funcional · use como guia para o package.json do projeto Next.js que vai consumir esses componentes.",
  "name": "r2-people",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:apply": "psql $DATABASE_URL -v ON_ERROR_STOP=1 -f supabase/00_local_setup.sql && for f in supabase/migrations/*.sql; do echo \"-- $f\"; psql $DATABASE_URL -v ON_ERROR_STOP=1 -f $f; done",
    "db:test": "for f in supabase/tests/*.sql; do echo \"-- $f\"; psql $DATABASE_URL -v ON_ERROR_STOP=1 -f $f; done"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "pdfjs-dist": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-pdf": "^7.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
